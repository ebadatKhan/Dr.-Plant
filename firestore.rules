rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'nickname', 'email', 'createdAt']) &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.nickname is string && data.nickname.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.createdAt == request.time;
    }

    function isValidScan(data) {
      return data.keys().hasAll(['userId', 'diseaseName', 'confidence', 'image', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.diseaseName is string && data.diseaseName.size() <= 200 &&
             data.confidence is number && data.confidence >= 0 && data.confidence <= 1 &&
             data.image is string && data.image.size() <= 1048576 &&
             data.createdAt == request.time &&
             (!('severity' in data) || data.severity in ['Low', 'Medium', 'High']);
    }

    // User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().email == existing().email;
    }

    // Scan Records
    match /scans/{scanId} {
      allow create: if isSignedIn() && isValidScan(incoming()) && 
                    exists(/databases/$(database)/documents/users/$(request.auth.uid));
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Chat Conversations
    match /chats/{chatId} {
      allow get, list, create, update: if isSignedIn() && incoming().userId == request.auth.uid;
      
      match /messages/{messageId} {
        allow list, create: if isSignedIn() && get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;
      }
    }
  }
}
